APP_NAME=CodeQuest Backend
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:5173

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_QUESTION_TABLE=generated_questions
SUPABASE_USER_TABLE=app_users
SUPABASE_RATE_LIMIT_TABLE=api_daily_usage

OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_CHAT_MODEL=arcee-ai/trinity-large-preview:free
OPENROUTER_REFERER=http://localhost:5173

AUTH_JWT_SECRET=change-this-to-a-long-random-secret
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=1440
AUTH_SUPER_ADMIN_EMAIL=you@example.com
AUTH_SUPER_ADMIN_PASSWORD=change-this-super-admin-password

RATE_LIMIT_DAILY_MAX=10
